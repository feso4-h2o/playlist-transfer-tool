# Playlist Transfer Tool environment example.
# The CLI expands these variables when they are referenced from playlist-porter.json.
# It does not auto-load this file; export the values in your shell or use your
# own local environment loader.

# Spotify OAuth app settings.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8080/callback
SPOTIFY_SCOPES=playlist-read-private playlist-read-collaborative playlist-modify-private playlist-modify-public

# QQ Music local session settings.
# Store credential JSON outside Git and point this variable at it.
QQMUSIC_CREDENTIAL_PATH=qqmusic-credential.json
QQMUSIC_USER_ID=
